# Copy to `.env` or `.env.local` (both are gitignored except this example file).
#
# Adobe Lightroom web client id — public, same value lightroom.adobe.com uses on share URLs (api_key=…).
# Not your Adobe password. Vercel/production: set this in the project Environment Variables UI.
NEXT_PUBLIC_ADOBE_LIGHTROOM_WEB_CLIENT_KEY=

# JSON: album `id` → plain password (server only). Keys must match each entry’s `id` in
# `components/photography/photographyAlbumEntries.ts` exactly.
# Verified via POST /api/photography/verify-gallery-password (body: `{ "id", "password" }`).
# Example (one album): {"album-1":"password-1", "album-2": "password-2"}
PHOTOGRAPHY_GALLERY_PASSWORDS=

# JSON: album `id` → full Lightroom share URL (server only — do not commit real URLs in repo).
# Same keys as PHOTOGRAPHY_GALLERY_PASSWORDS. Returned only after correct password.
# Example: {"2026-04-japan":"https://adobe.ly/your-short-link"}
PHOTOGRAPHY_GALLERY_SHARE_URLS=

# WoW — Battle.net Profile API (optional, server-only). https://developer.battle.net/
# Enable WoW Profile APIs on the application. Without these, ilvl/class use roster JSON fallbacks.
# For live Mythic+ rating, also enable WoW Game Data APIs (season index → keystone season profile).
BATTLENET_CLIENT_ID=
BATTLENET_CLIENT_SECRET=

# WoW group detail pages (`/wow/groups/[groupId]`) — optional password gate.
# `WOW_GROUP_PASSWORDS` keys must match `groups[].id` in `components/wow/config/wowRoster.json`.
# Generate a long random string for `WOW_GROUP_SECRET` (used to sign the httpOnly grant cookie).
# The grant cookie is a browser session cookie (no fixed expiry) and is cleared when navigating away from a group detail page (`POST /api/wow/revoke-group-access`) or when the browser session ends.
# Gated groups open from the list via `/wow?gate={groupId}` (modal); direct hits to `/wow/groups/{id}` without a grant redirect there. Roster data is not enriched until access is granted.# Example: {"tuesday-raid":"password-1","mythic-saturdays":"password-2"}
WOW_GROUP_SECRET=
WOW_GROUP_PASSWORDS=
